# Hammer and Sickle — code-only repository.
# Policy: track ONLY C# source (*.cs) and this .gitignore. Everything else
# (Unity assets, meta files, generated folders, binaries) is ignored.

# --- Ignore everything by default ---
*

# --- but let git descend into directories so it can find .cs files ---
!*/

# --- keep C# source and this ignore file ---
!*.cs
!.gitignore

# --- Re-ignore generated / external folders ENTIRELY (even .cs inside them).
#     These must come last so they win over the !*/ rule above.
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Mm]emoryCaptures/
/[Rr]ecordings/
/[Uu]ser[Ss]ettings/
.vs/
.gradle/
.consulo/
.utmp/
